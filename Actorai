        "# ==========================================================\n",
        "# ACTFORGE V22.2 - TURBO-TITAN (SPEED OPTIMIZED)\n",
        "# Goal: 3,000 Videos | Speed: High-Velocity Processing\n",
        "# ==========================================================\n",
        "\n",
        "import os, json, cv2, torch, whisper, time, random, requests\n",
        "from PIL import Image\n",
        "from transformers import pipeline, AutoProcessor, BlipForConditionalGeneration\n",
        "\n",
        "DEVICE = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
        "PEXELS_API_KEY = \"jkPNHnfuERGHAWT9BNIszjMGVmk4wecTK1mHJuipOHbjKvS3ovY85tM6\"\n",
        "MEMORY_FILE = \"actforge_library_memory.json\"\n",
        "TARGET_GOAL = 3000\n",
        "\n",
        "class TurboTitan:\n",
        "    def __init__(self, api_key):\n",
        "        print(f\"🚀 TURBO ENGINE ONLINE (Device: {DEVICE})\")\n",
        "        self.api_key = api_key\n",
        "        self.processor = AutoProcessor.from_pretrained(\"Salesforce/blip-image-captioning-base\")\n",
        "        self.vision = BlipForConditionalGeneration.from_pretrained(\"Salesforce/blip-image-captioning-base\").to(DEVICE)\n",
        "        self.ear = whisper.load_model(\"tiny\")\n",
        "        self.curriculum = [\"crying\", \"shouting\", \"laughing\", \"angry face\", \"whispering\", \"fear\"]\n",
        "        self.load_memory()\n",
        "\n",
        "    def load_memory(self):\n",
        "        if os.path.exists(MEMORY_FILE):\n",
        "            with open(MEMORY_FILE, 'r') as f: self.memory = json.load(f)\n",
        "        else:\n",
        "            self.memory = {\"total_scenes\": 0, \"emotion_stats\": {}}\n",
        "\n",
        "    def fetch_fast(self):\n",
        "        \"\"\"Fetches the smallest possible video file for maximum speed.\"\"\"\n",
        "        query = random.choice(self.curriculum)\n",
        "        # Randomize page heavily to ensure unique videos\n",
        "        url = f\"https://api.pexels.com/videos/search?query={query}&per_page=1&page={random.randint(1, 500)}\"\n",
        "        headers = {\"Authorization\": self.api_key}\n",
        "\n",
        "        try:\n",
        "            response = requests.get(url, headers=headers).json()\n",
        "            if 'videos' not in response or not response['videos']: return False\n",
        "\n",
        "            # Find the 'mobile' or lowest res file link\n",
        "            files = response['videos'][0]['video_files']\n",
        "            # Sort by width to find the smallest file\n",
        "            files.sort(key=lambda x: x['width'] or 9999)\n",
        "            video_url = files[0]['link']\n",
        "\n",
        "            # Stream download to disk\n",
        "            r = requests.get(video_url, stream=True)\n",
        "            with open(\"scene.mp4\", 'wb') as f:\n",
        "                for chunk in r.iter_content(chunk_size=1024*512): # 512KB chunks\n",
        "                    if chunk: f.write(chunk)\n",
        "            return True\n",
        "        except:\n",
        "            return False\n",
        "\n",
        "    def analyze_fast(self):\n",
        "        \"\"\"Ultra-fast frame analysis.\"\"\"\n",
        "        cap = cv2.VideoCapture(\"scene.mp4\")\n",
        "        emotions = []\n",
        "        # Sample only 5 key frames per video to determine the 'truth'\n",
        "        count = 0\n",
        "        while cap.isOpened() and len(emotions) < 5:\n",
        "            ret, frame = cap.read()\n",
        "            if not ret: break\n",
        "\n",
        "            if count % 45 == 0: # Check roughly every 1.5 seconds\n",
        "                img = Image.fromarray(cv2.cvtColor(cv2.resize(frame, (128, 128)), cv2.COLOR_BGR2RGB))\n",
        "                inputs = self.processor(images=img, return_tensors=\"pt\").to(DEVICE)\n",
        "                out = self.vision.generate(**inputs, max_new_tokens=10)\n",
        "                desc = self.processor.decode(out[0], skip_special_tokens=True).lower()\n",
        "\n",
        "                emo = \"Vulnerable\" if \"sad\" in desc else \"Intense\" if \"ang\" in desc else \"Grounded\"\n",
        "                emotions.append(emo)\n",
        "            count += 1\n",
        "        cap.release()\n",
        "        return max(set(emotions), key=emotions.count) if emotions else \"Neutral\"\n",
        "\n",
        "    def train(self):\n",
        "        while self.memory['total_scenes'] < TARGET_GOAL:\n",
        "            # Step 1: Rapid Download\n",
        "            if self.fetch_fast():\n",
        "                # Step 2: Rapid Analysis\n",
        "                emo = self.analyze_fast()\n",
        "\n",
        "                # Step 3: Record Progress\n",
        "                self.memory['total_scenes'] += 1\n",
        "                self.memory['emotion_stats'][emo] = self.memory['emotion_stats'].get(emo, 0) + 1\n",
        "\n",
        "                # Batch saving: only write to disk every 5 videos to save time\n",
        "                if self.memory['total_scenes'] % 5 == 0:\n",
        "                    with open(MEMORY_FILE, 'w') as f: json.dump(self.memory, f)\n",
        "                    print(f\"🔥 BATCH COMPLETE: Total {self.memory['total_scenes']}/{TARGET_GOAL}\")\n",
        "                else:\n",
        "                    print(f\"⚡ Lesson {self.memory['total_scenes']} done.\", end=\"\\r\")\n",
        "\n",
        "                # Remove file immediately\n",
        "                if os.path.exists(\"scene.mp4\"): os.remove(\"scene.mp4\")\n",
        "\n",
        "            # NO SLEEP TIMER - Full speed ahead!\n",
        "\n",
        "# --- EXECUTE ---\n",
        "titan = TurboTitan(PEXELS_API_KEY)\n",
        "titan.train()\n",
        "titan.curriculum = [\n",
        "    \"crying closeup\", \"angry screaming\", \"intense argument\",\n",
        "    \"sob story\", \"furious person\", \"terrified face\",\n",
        "    \"despair acting\", \"shouting match\"\n",
        "]\n",
        "print(\"🎯 CURRICULUM UPDATED: The AI is now hunting for extreme drama.\")"
